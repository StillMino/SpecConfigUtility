<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SpecConfigUI.ViewModels"
             xmlns:core="using:SpecConfig.Core.Models"
             xmlns:converters="using:SpecConfigUI.Converters"
             x:Class="SpecConfigUI.Views.ProfileEditorView"
             x:DataType="vm:ProfileEditorViewModel">

    <UserControl.Resources>
        <converters:IndexGreaterThanZeroConverter x:Key="GreaterThanZero"/>
        <converters:IndexLessThanCountMinusOneConverter x:Key="LessThanCountMinusOne"/>
    </UserControl.Resources>

    <DockPanel Margin="8">
        <!-- Панель инструментов -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Command="{Binding AddFieldCommand}" Content="➕ Добавить поле" 
                    IsEnabled="{Binding SelectedTable, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            <TextBlock Text="Поля таблицы:" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding SelectedTableFields.Count}" VerticalAlignment="Center" 
                       Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
        </StackPanel>

        <!-- Основная область: список таблиц + редактор полей -->
        <Grid ColumnDefinitions="200,*">
            <!-- Список таблиц -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                    BorderThickness="1" Margin="0,0,8,0" CornerRadius="4">
                <ListBox ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable}" 
                         Margin="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Caption}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Редактор полей -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                    BorderThickness="1" CornerRadius="4">
                <DockPanel Margin="8">
                    <!-- DataGrid с полями -->
                    <DataGrid ItemsSource="{Binding SelectedTableFields}" 
                                 SelectedItem="{Binding SelectedField}"
                                 AutoGenerateColumns="False" 
                                 CanUserSortColumns="False"
                                 Margin="0,0,0,8"
                                 DockPanel.Dock="Top">
                        <DataGrid.Columns>
                            <!-- Кнопки сортировки -->
                            <DataGridTemplateColumn Header="↕" Width="60" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
                                            <Button Command="{Binding $parent[DataGrid].DataContext.MoveUp}" 
                                                    CommandParameter="{Binding}" Content="⬆" Padding="2,0" 
                                                    IsEnabled="{Binding Index, RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource GreaterThanZero}}"/>
                                            <Button Command="{Binding $parent[DataGrid].DataContext.MoveDown}" 
                                                    CommandParameter="{Binding}" Content="⬇" Padding="2,0"
                                                    IsEnabled="{Binding Index, RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource LessThanCountMinusOne}, ConverterParameter={Binding $parent[DataGrid].DataContext.SelectedTableFields}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Поля для редактирования -->
                            <DataGridTextColumn Header="Наименование" Binding="{Binding Caption}" Width="1.5*"/>
                            <DataGridTextColumn Header="BOM-поле" Binding="{Binding Data}" Width="1*"/>
                            <DataGridCheckBoxColumn Header="Агрегат" Binding="{Binding Aggregate}" Width="80"/>
                            <DataGridCheckBoxColumn Header="Видимость" Binding="{Binding Visible}" Width="90"/>
                            <DataGridTextColumn Header="Формат" Binding="{Binding Format}" Width="1*"/>

                            <!-- Действия -->
                            <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding $parent[DataGrid].DataContext.Remove}" 
                                                CommandParameter="{Binding}" Content="🗑" Foreground="Red" 
                                                Padding="4,2" ToolTip.Tip="Удалить поле"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Кнопки действий -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Command="{Binding CancelChangesCommand}" Content="❌ Отмена" 
                                IsEnabled="{Binding State.HasChanges}"/>
                        <Button Command="{Binding ApplyChangesCommand}" Content="✅ Применить" 
                                IsEnabled="{Binding State.HasChanges}" Classes="Accent"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Статус и ошибки -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock Text="{Binding State.ErrorMessage}" Foreground="Red" TextWrapping="Wrap" 
                       IsVisible="{Binding State.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="{Binding State.StatusMessage}" Foreground="Gray" FontSize="11"/>
        </StackPanel>
    </DockPanel>
</UserControl>
