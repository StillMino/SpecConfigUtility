<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpecConfigUI.ViewModels"
        x:Class="SpecConfigUI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="SpecConfig Utility" Width="900" Height="600"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="SpecConfig Utility" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding StatusText}" Foreground="Gray"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding ConnectToCadCommand}" Content="Подключиться к nanoCAD"/>
            <Button Command="{Binding GetDocNameCommand}" Content="Получить имя документа" IsEnabled="{Binding IsCadConnected}"/>
        </StackPanel>
    </DockPanel>
</Window>
